#!/bin/bash

# DZH DeepSeek自然语言对话工具
# 支持与DeepSeek进行真实的自然语言交流

SCRIPT_DIR="/home/ddo/.config/claude-tools"
CHAT_TOOL="$SCRIPT_DIR/dzh_deepseek_chat.py"

# 检查Python文件是否存在
if [[ ! -f "$CHAT_TOOL" ]]; then
    echo "❌ 找不到DeepSeek聊天工具: $CHAT_TOOL"
    exit 1
fi

show_help() {
    echo "💬 DZH DeepSeek自然语言对话工具"
    echo "=============================="
    echo ""
    echo "用法: $0 [选项] [消息]"
    echo ""
    echo "选项:"
    echo "  --interactive, -i    - 启动交互式对话模式"
    echo "  --analyze <股票代码>  - 分析指定股票"
    echo "  --market             - 市场整体分析"
    echo "  --help, -h           - 显示帮助信息"
    echo ""
    echo "示例:"
    echo "  $0 \"分析今天深圳市场走势\"           - 发送单条消息"
    echo "  $0 -i                                  - 启动交互模式"
    echo "  $0 --analyze 000001                   - 分析平安银行"
    echo "  $0 --market                           - 市场分析"
    echo ""
    echo "快捷命令:"
    echo "  ds-chat <消息>    - 发送消息给DeepSeek"
    echo "  ds-i              - 启动交互模式"
    echo "  ds-stock <代码>   - 分析股票"
    echo "  ds-market         - 市场分析"
}

send_single_message() {
    local message="$*"

    if [[ -z "$message" ]]; then
        echo "❌ 请输入要发送的消息"
        echo "💡 使用: $0 \"您的消息\""
        exit 1
    fi

    echo "💬 正在向DeepSeek发送消息: $message"
    echo "----------------------------------------"

    python3 -c "
import asyncio
import sys
sys.path.append('$SCRIPT_DIR')
from dzh_deepseek_chat import DZHDeepSeekChatInterface

async def send_message():
    chat = DZHDeepSeekChatInterface()
    try:
        if await chat.initialize():
            result = await chat.send_message('$message')
            if result['success']:
                print('🤖 DeepSeek回复:')
                print(result['response'])
            else:
                print(f'❌ 失败: {result[\"error\"]}')
        else:
            print('❌ 初始化失败')
    finally:
        await chat.close()

asyncio.run(send_message())
"
}

analyze_stock() {
    local stock_code="$1"

    if [[ -z "$stock_code" ]]; then
        echo "❌ 请输入股票代码"
        echo "💡 使用: $0 --analyze <股票代码>"
        exit 1
    fi

    echo "📈 正在分析股票: $stock_code"
    echo "---------------------------"

    python3 -c "
import asyncio
import sys
sys.path.append('$SCRIPT_DIR')
from dzh_deepseek_chat import DZHDeepSeekChatInterface

async def analyze():
    chat = DZHDeepSeekChatInterface()
    try:
        if await chat.initialize():
            result = await chat.analyze_stock('$stock_code')
            if result['success']:
                print('🤖 DeepSeek股票分析:')
                print(result['response'])
            else:
                print(f'❌ 分析失败: {result[\"error\"]}')
        else:
            print('❌ 初始化失败')
    finally:
        await chat.close()

asyncio.run(analyze())
"
}

market_analysis() {
    echo "📊 正在进行市场分析..."
    echo "----------------------"

    python3 -c "
import asyncio
import sys
sys.path.append('$SCRIPT_DIR')
from dzh_deepseek_chat import DZHDeepSeekChatInterface

async def market():
    chat = DZHDeepSeekChatInterface()
    try:
        if await chat.initialize():
            result = await chat.market_analysis()
            if result['success']:
                print('🤖 DeepSeek市场分析:')
                print(result['response'])
            else:
                print(f'❌ 分析失败: {result[\"error\"]}')
        else:
            print('❌ 初始化失败')
    finally:
        await chat.close()

asyncio.run(market())
"
}

start_interactive() {
    echo "🎭 启动DZH DeepSeek交互式对话模式"
    echo "==================================="
    echo "💡 提示: 输入 'help' 查看可用命令，输入 'quit' 退出"
    echo ""

    python3 "$CHAT_TOOL"
}

# 主逻辑
case "${1:-}" in
    "--interactive"|"-i"|"")
        start_interactive
        ;;
    "--analyze"|"--stock")
        analyze_stock "$2"
        ;;
    "--market"|"--market-analysis")
        market_analysis
        ;;
    "--help"|"-h"|"help")
        show_help
        ;;
    *)
        # 如果不是选项，则当作消息发送
        send_single_message "$@"
        ;;
esac