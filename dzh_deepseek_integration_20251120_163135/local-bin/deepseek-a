#!/bin/bash

# DeepSeek 简化版分析工具 - 用户友好版

show_help() {
    echo "🤖 DeepSeek AI 分析工具"
    echo "====================="
    echo ""
    echo "用法: deepseek-a [市场] [选项]"
    echo ""
    echo "市场选项:"
    echo "  sz, 深圳, shenzhen     - 深圳成指分析"
    echo "  sh, 上海, shanghai    - 上证指数分析"
    echo "  cy, 创业, chuangye    - 创业板分析"
    echo "  zx, 中证, zhongzheng   - 中证指数分析"
    echo ""
    echo "快速命令:"
    echo "  deepseek-a              - 默认深圳市场分析"
    echo "  deepseek-a sz            - 深圳市场分析"
    echo "  deepseek-a sh            - 上海市场分析"
    echo ""
    echo "选项:"
    echo "  --tech, -t              - 详细技术指标"
    echo "  --hot, -h               - 热点板块分析"
    echo "  --risk, -r              - 风险评估"
    echo "  --short, -s             - 简要摘要"
    echo "  --help, -help           - 显示帮助"
}

show_quick_summary() {
    local market="$1"
    local market_name="$2"

    echo "🔍 $market_name 快速摘要"
    echo "=================="

    python3 -c "
import sys
sys.path.append('/home/ddo/.config/claude-tools')
from claude_deepseek_bridge import ClaudeDeepSeekBridge
bridge = ClaudeDeepSeekBridge()
data = bridge.get_market_data('$market')
print(f'📊 {data[\"market\"]} ({data[\"code\"]})')
print(f'📍 当前点位: {data[\"current_price\"]}')
print(f'📈 涨跌幅: {data[\"change\"]} ({data[\"change_percent\"]})')
print(f'💰 成交量: {data[\"volume\"]}')
print(f'⏰ 状态: {data[\"status\"]}')
print(f'⏱️ 更新时间: {data[\"timestamp\"]}')
    "
}

show_detailed_analysis() {
    local market="$1"
    local market_name="$2"
    local options="$3"

    echo "🎯 $market_name 详细分析"
    echo "======================"

    python3 -c "
import sys
sys.path.append('/home/ddo/.config/claude-tools')
from claude_deepseek_bridge import ClaudeDeepSeekBridge
bridge = ClaudeDeepSeekBridge()
data = bridge.get_market_data('$market')
indicators = bridge.analyze_technical_indicators('$market' == '399001' and '399001' or '000001')
sectors = bridge.get_hot_sectors()

print('📊 基础数据')
print(f'指数代码: {data[\"code\"]} | 当前点位: {data[\"current_price\"]} | 涨跌幅: {data[\"change\"]}')
print(f'成交量: {data[\"volume\"]} | 成交额: {data.get(\"turnover\", \"未知\")} | 状态: {data[\"status\"]}')

print('')
print('📈 技术指标')
print(f'MACD: {indicators[\"MACD\"][\"status\"]} ({indicators[\"MACD\"][\"signal\"]})')
print(f'KDJ: {indicators[\"KDJ\"][\"status\"]} ({indicators[\"KDJ\"][\"signal\"]})')
print(f'RSI: {indicators[\"RSI\"][\"value\"]} ({indicators[\"RSI\"][\"status\"]})')
print(f'MA系统: MA5={indicators[\"MA5\"]} MA10={indicators[\"MA10\"]} MA20={indicators[\"MA20\"]}')
print(f'量比: {indicators[\"volume_ratio\"]} | 振幅: {indicators[\"amplitude\"]}')

print('')
print('🔥 热点板块 TOP3')
for i, sector in enumerate(sectors[:3], 1):
    print(f'{i}. {sector[\"name\"]}: {sector[\"change\"]} | {sector[\"leaders\"][0]}')
    "

    # 如果包含风险评估选项
    if [[ "$options" == *risk* ]] || [[ "$options" == *-r* ]]; then
        echo ""
        echo "⚠️ 风险评估"
        echo "---------"
        python3 -c "
import sys
sys.path.append('/home/ddo/.config/claude-tools')
from claude_deepseek_bridge import ClaudeDeepSeekBridge
bridge = ClaudeDeepSeekBridge()
data = bridge.get_market_data('$market')
indicators = bridge.analyze_technical_indicators('$market' == '399001' and '399001' or '000001')

rsi_value = indicators['RSI']['value']
kdj_status = indicators['KDJ']['status']

risk_level = '低风险'
if rsi_value > 70:
    risk_level = '⚠️ 高风险'
elif rsi_value > 60:
    risk_level = '⚡ 中风险'

print(f'风险等级: {risk_level}')
print(f'技术面: {\"强势\" if rsi_value > 50 else \"弱势\"} | 资金面: {\"活跃\" if data.get(\"volume\", \"0\") != \"0\" else \"低迷\"}')
        "
    fi
}

show_hot_sectors() {
    echo "🔥 今日热点板块"
    echo "================"

    python3 -c "
import sys
sys.path.append('/home/ddo/.config/claude-tools')
from claude_deepseek_bridge import ClaudeDeepSeekBridge
bridge = ClaudeDeepSeekBridge()
sectors = bridge.get_hot_sectors()

for i, sector in enumerate(sectors, 1):
    emoji = '🔥' if i <= 3 else '📈'
    print(f'{emoji} {sector[\"name\"]:12} | {sector[\"change\"]:8} | {sector[\"leaders\"][0]}')
    "
}

# 主逻辑
market="${1:-sz}"
options="$2"

case "$market" in
    "sz"|"深圳"|"shenzhen"|"default")
        if [[ "$options" == "--short" ]] || [[ "$options" == "-s" ]]; then
            show_quick_summary "深圳" "深圳成指"
        elif [[ "$options" == "--hot" ]] || [[ "$options" == "-h" ]]; then
            show_hot_sectors
        elif [[ "$options" == "--risk" ]] || [[ "$options" == "-r" ]]; then
            show_detailed_analysis "深圳" "深圳成指" "--risk"
        else
            show_detailed_analysis "深圳" "深圳成指" ""
        fi
        ;;
    "sh"|"上海"|"shanghai")
        if [[ "$options" == "--short" ]] || [[ "$options" == "-s" ]]; then
            show_quick_summary "上海" "上证指数"
        elif [[ "$options" == "--hot" ]] || [[ "$options" == "-h" ]]; then
            show_hot_sectors
        else
            show_detailed_analysis "上海" "上证指数" ""
        fi
        ;;
    "cy"|"创业"|"chuangye")
        show_quick_summary "创业板" "创业板指数"
        ;;
    "zx"|"中证"|"zhongzheng")
        show_quick_summary "中证" "中证指数"
        ;;
    "--help"|"-h"|"help")
        show_help
        ;;
    *)
        echo "❓ 未识别的市场: $market"
        echo ""
        echo "💡 使用 'deepseek-a --help' 查看帮助"
        echo "💡 默认分析深圳市场: deepseek-a"
        ;;
esac

echo ""
echo "✅ 分析完成 | 💡 使用 'deepseek-a sz --hot' 查看热点"