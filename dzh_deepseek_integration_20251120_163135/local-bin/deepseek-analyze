#!/bin/bash

# DeepSeek市场分析工具

echo "🚀 DeepSeek市场分析工具 v1.0"
echo "============================"

# 检查Python环境
if ! command -v python3 &> /dev/null; then
    echo "❌ 未找到Python3，请先安装Python3"
    exit 1
fi

# 检查桥接器
BRIDGE_TOOL="/home/ddo/.config/claude-tools/claude_deepseek_bridge.py"
if [[ ! -f "$BRIDGE_TOOL" ]]; then
    echo "❌ 未找到DeepSeek桥接器"
    exit 1
fi

case "${1:-analyze}" in
    "shenzhen"|"sz"|"深圳")
        echo "🔍 分析深圳市场..."
        python3 "$BRIDGE_TOOL" shenzhen
        ;;
    "shanghai"|"sh"|"上海")
        echo "🔍 分析上海市场..."
        # 这里可以扩展上海市场分析
        python3 -c "
import sys
sys.path.append('/home/ddo/.config/claude-tools')
from claude_deepseek_bridge import ClaudeDeepSeekBridge
bridge = ClaudeDeepSeekBridge()
data = bridge.get_market_data('上海')
indicators = bridge.analyze_technical_indicators('000001')
print(f'🎯 {data[\"market\"]}分析')
print(f'当前点位: {data[\"current_price\"]}')
print(f'涨跌幅: {data[\"change\"]}')
print(f'成交量: {data[\"volume\"]}')
print(f'RSI指标: {indicators[\"RSI\"][\"value\"]}')
        "
        ;;
    "token"|"switch")
        echo "🔄 切换到DeepSeek模式..."
        python3 "$BRIDGE_TOOL" switch
        ;;
    "help"|"-h"|"--help")
        echo "用法: $0 [command]"
        echo ""
        echo "命令:"
        echo "  shenzhen, sz, 深圳  - 分析深圳市场"
        echo "  shanghai, sh, 上海  - 分析上海市场"
        echo "  token, switch       - 切换DeepSeek模式"
        echo "  help               - 显示帮助信息"
        ;;
    *)
        echo "🔍 默认分析深圳市场..."
        python3 "$BRIDGE_TOOL" shenzhen
        ;;
esac

echo ""
echo "✅ 分析完成"
echo "💡 提示: 使用 'quick-switch.sh deepseek' 切换AI模型"