# NVM状态检查函数
nvm_status() {
    echo "=== NVM与NPM状态 ==="
    echo "NVM版本: $(nvm --version 2>/dev/null || echo '未加载')"
    echo "Node.js版本: $(node --version 2>/dev/null || echo '未安装')"
    echo "NPM版本: $(npm --version 2>/dev/null || echo '未安装')"
    echo "当前NVM版本: $(nvm current 2>/dev/null || echo '无')"
    echo "NPM前缀: $(npm config get prefix 2>/dev/null || echo '未知')"
    echo "NPM缓存: $(npm config get cache 2>/dev/null || echo '未知')"
}

# 冲突检测函数
check_nvm_npm_conflict() {
    if [[ -f ~/.npmrc ]] && grep -q "prefix=" ~/.npmrc; then
        echo "⚠️  检测到.npmrc中的prefix配置可能导致NVM冲突"
        echo "建议: 移除prefix配置，让NVM管理路径"
        return 1
    else
        echo "✅ 无NVM/NPM配置冲突"
        return 0
    fi
}

