<?xml version="1.0" encoding="UTF-8" ?>

<!--
section 属性
  type: 类型。表示文件属于什么类型
    1: 表示 信息地雷删除 文件
	2: 表示 财务 文件
	3: 表示 除权 文件
	4: 表示 PETTM 文件
	5: 表示 abk 文件
	
  maxdelay: 表示该节点内的文件，在收到文件订阅通知时，随机等待 [1，maxdelay] 秒后再去同步文件，该值默认 60
  
item 属性
  file: 文件名称，包含相对目录， 比如 "mine/demine.dat"
  maxdelay: 表示该文件在收到订阅通知时，随机等待 [1，maxdelay] 秒后再去同步文件， 该值优先级高于 section 中的 maxdelay
  market: 表示该文件需要等待相关市场码表加载完成之后，才发送文件同步请求
-->

<root>
    <section type="1" maxdelay="10">
        <item file="/mine/demine.dat"/>
    </section>
    <section type="2">
		<item file="fin/full_sh.FIN" market="SH"/>
		<item file="fin/full_sz.FIN" market="SZ"/>
		<item file="fin/full_bj.FIN" market="BJ"/>
    </section>
    <section type="3">
		<item file="pwr/full_sh.PWR" market="SH"/>
		<item file="pwr/full_sz.PWR" market="SZ"/>
		<item file="pwr/full_bj.PWR" market="BJ"/>
    </section>
    <section type="4">
		<item file="uasfinance/SHNowFinInfo.dat"/>
		<item file="uasfinance/SZNowFinInfo.dat"/>
    </section>
    <section type="5">
		<item file="abk/full.ABK"/>
		<item file="abk/inc.ABK"/>
    </section>
</root>
