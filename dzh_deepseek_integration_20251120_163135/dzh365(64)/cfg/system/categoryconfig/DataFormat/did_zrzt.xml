<?xml version="1.0" encoding="GB2312"?>
<rules target="quote_dyna">
	<rule id="rule_dyna1">
    <conditions>
      <condition>matchtype=col</condition>
      <condition>tablename=.*</condition>
      <condition>tabletype=.*</condition>
	  <condition>colname=CQCX</condition>
    </conditions>
    <actions>
      <action type="need_fmt">1</action>
		<action type="func_param">{"N":"正常状态","E":"除权","D":"除息","A":"除权除息"}</action>
		<action type="fmt_func">cfmt_directory</action>           
		<action type="new_name">转让状态</action>
    </actions>
  </rule> 
	<rule id="rule_dyna2">
		<conditions>
			<condition>matchtype=col</condition>
			<condition>tablename=.*</condition>
			<condition>tabletype=.*</condition>
			<condition>colname=ZRZT</condition>
		</conditions>
		<actions>
			<action type="need_fmt">1</action>
			<action type="func_param">{"N":"正常状态","Y":"首日挂牌","D":"新增股票挂牌"}</action>
			<action type="fmt_func">cfmt_directory</action>           
			<action type="new_name">转让状态</action>
		</actions>
	</rule>
	<rule id="rule_dyna3">
		<conditions>
			<condition>matchtype=col</condition>
			<condition>tablename=.*</condition>
			<condition>tabletype=.*</condition>
			<condition>colname=TPBZ</condition>
		</conditions>
		<actions>
			<action type="need_fmt">1</action>
			<action type="func_param">{"F":"正常转让","T":"停牌不接受申报","H":"停牌接受申报"}</action>
			<action type="fmt_func">cfmt_directory</action>           
			<action type="new_name">停牌标志</action>
		</actions>
	</rule>
	<rule id="rule_dyna4">
		<conditions>
			<condition>matchtype=col</condition>
			<condition>tablename=.*</condition>
			<condition>tabletype=.*</condition>
			<condition>colname=transfer_type</condition>
		</conditions>
		<actions>
			<action type="need_fmt">1</action>
			<action type="func_param">{"T":"大宗交易","M":"做市交易","B":"集合竞价和连续竞价交易","C":"集合竞价交易","O":"其他类型"}</action>
			<action type="fmt_func">cfmt_directory</action>           
			<action type="new_name">转让方式</action>
		</actions>
	</rule>
	<rule id="rule_dyna5">
		<conditions>
			<condition>matchtype=col</condition>
			<condition>tablename=.*</condition>
			<condition>tabletype=.*</condition>
			<condition>colname=level</condition>
		</conditions>
		<actions>
			<action type="need_fmt">1</action>
			<action type="func_param">{"1":"基础层","2":"创新层"}</action>
			<action type="fmt_func">cfmt_directory</action>           
			<action type="new_name">分层信息</action>
		</actions>
	</rule>

</rules>