<?xml version="1.0" encoding="GB2312"?>
<rules target="quote_dyna">
  <rule id="rule_dyna1">
    <conditions>
      <condition>matchtype=col</condition>
      <condition>tablename=.*</condition>
      <condition>tabletype=.*</condition>
	  <condition>colname=OpenInterest</condition>
    </conditions>
    <actions>
      <action type="need_fmt">1</action>
      <action type="func_param">{"sc":"LST_data","digit":"0","prefix":"&lt;*sf=PLUG_data*&gt;&lt;*b=1*&gt;"}</action>
      <action type="fmt_func">cfmt_default_volume</action>           
      <action type="new_name">期转现日增仓</action>
    </actions>
  </rule>
  <rule id="rule_dyna2">
    <conditions>
      <condition>matchtype=col</condition>
      <condition>tablename=.*</condition>
      <condition>tabletype=.*</condition>
	  <condition>colname=Volume</condition>
    </conditions>
    <actions>
      <action type="need_fmt">1</action>
      <action type="func_param">{"sc":"LST_data","digit":"0","prefix":"&lt;*sf=PLUG_data*&gt;&lt;*b=1*&gt;"}</action>
	  <action type="fmt_func">cfmt_default_volume</action>           
      <action type="new_name">期转现成交量</action>
    </actions>
  </rule>
  
</rules>