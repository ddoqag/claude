function cyzs()
	this.ResetStocks();

	if this.ColCount() == 0 
		index = this.InsertQuotation(-1,'序号'); 
		this.SetColumnAttributes(index,'',60,0,0);  
		index = this.InsertQuotation(-1,'代码');
		this.SetColumnAttributes(index,'',70,0,0); 
		index = this.InsertQuotation(-1,'名称');
		this.SetColumnAttributes(index,'',180,0,0); 
		index = this.InsertQuotation(-1,'最新');
		this.SetColumnAttributes(index,'',90,0,0);  
		index = this.InsertQuotation(-1,'涨跌');
		this.SetColumnAttributes(index,'',70,0,0); 
		index = this.InsertQuotation(-1,'涨幅');
		this.SetColumnAttributes(index,'',70,0,0);
		index = this.InsertQuotation(-1,'今开');
		this.SetColumnAttributes(index,'',90,0,0); 
		index = this.InsertQuotation(-1,'昨收');
		this.SetColumnAttributes(index,'',90,0,0); 
		index = this.InsertQuotation(-1,'最高');
		this.SetColumnAttributes(index,'',90,0,0); 
		index = this.InsertQuotation(-1,'最低');
		this.SetColumnAttributes(index,'',90,0,0); 
	end
	
	{计算起始行号}
	start = this.StockCount() + 1;
	this.AddStringLine('沪深京指数');
	table =['SH000001','SZ399001','BJ899050','SZ399006','SH000680','SH000688','SH000888','SH000300','SH000016','SZ399330','SZ399673','SH000905','ZI000510','SH000852','SH000690','SH000698'];
	this.SetStocks(table(1,:),1);
	
	{计算起始行号}
	this.AddStringLine('A股期指');
	table =['SFIF0001','SFIH0001','SFIC0001','SFIM0001','HFMCAY0','SMCNY0'];
	this.SetStocks(table(1,:),1);	

	{计算起始行号}
	this.AddStringLine('亚太股指');
	table =['HKHSI','XAN225','XAXIN9','XAKS11','CMNIYW0'];
	this.SetStocks(table(1,:),1);	
	
	
	{计算起始行号}
	this.AddStringLine('美国股指');
	table =['XMDJIA','XMSPX','XMNDX','XMHXC','CBYMW0','CMMESW0','CMMNQW0'];
	this.SetStocks(table(1,:),1);	
	
	
	{计算起始行号}
	this.AddStringLine('欧洲市场');
	table =['XEFTSE','XEGDAXI','XEFCHI','XESX5E','XEAEX','XEIBEX','XES30','XERTS'];
	this.SetStocks(table(1,:),1);	

	{计算起始行号}
	this.AddStringLine('全球ETF');
	table =['SH513520','SH513100','SH513850','SH513130','AMEWT','AMYINN','AMYANG','AMVIXY','AMKWEB'];
	this.SetStocks(table(1,:),1);	
	
	{计算起始行号}
	this.AddStringLine('大宗商品');
	table =['NXCLY0','NXCLW0','NXXBZY0','FXXAUUSD','FXXAGUSD','NCBC0001','CBZNW0','CBZFW0','CBZTW0'];
	this.SetStocks(table(1,:),1);
	
	{计算起始行号}
	this.AddStringLine('汇率市场');
	table =['IXUDI','FXUSDCNY','FXUSDCNH','FXEURUSD','FXGBPUSD','FXUSDJPY','FXUSDRUB'];
	this.SetStocks(table(1,:),1);

end

