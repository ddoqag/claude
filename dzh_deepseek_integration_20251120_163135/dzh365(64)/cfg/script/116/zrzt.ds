{在列尾插入一列行情，无返回值
colname 列名
type    数据类型，例如：'S'
width   列宽}
function InsertQuotation(colname, type, width)
	index = this.InsertQuotation(-1, colname);
	this.SetColumnAttributes(index, type, width,4294967295,4294967295); 
end

{在列尾插入一列静态数据，无返回值
colname 列名
id      识别码
type    数据类型，例如：'S'
width   列宽}
function InsertStatic(colname, id, type, width)
	index = this.InsertStatic(-1, colname, id);
	this.SetColumnAttributes(index, type, width,4294967295,4294967295); 
end

{设置列元素值
matrixdata 列数据
colname    列名
id         识别码
start      起始数据行号，从1开始}
function SetStatic(matrixdata, colname, id, start)
	this.SetStaticData(matrixdata, this.FindStatic(colname , id, 0), start);
end
{新加}
function zrzt()
	this.ResetStocks();
	
	table =DZH::requestyundatapb('/markettrend/block?field=ZiRanZhangTingGuPiaoLieBiao&output=pb&yesterday=1');
	index = table::GetColumnIndex(table, 'ZiRanZhangTingGuPiaoLieBiao');
	if(util::GetRows(table(1,index)) ~= 0)
		this.AddStringLine('自然板');
		this.SetStocks(table(1,index),1);
	end
	
	
	table =DZH::requestyundatapb('/markettrend/block?field=YiZhiZhangTingGuPiaoLieBiao&output=pb&yesterday=1');
	index = table::GetColumnIndex(table, 'YiZhiZhangTingGuPiaoLieBiao');
	if(util::GetRows(table(1,index)) ~= 0)
		this.AddStringLine('一字板');
		this.SetStocks(table(1,index),1);
	end
	
	
	table =DZH::requestyundatapb('/markettrend/block?field=STZhangTingGuPiaoLieBiao&output=pb&yesterday=1');
	index = table::GetColumnIndex(table, 'STZhangTingGuPiaoLieBiao');
	if(util::GetRows(table(1,index)) ~= 0)
		this.AddStringLine('ST股');
		this.SetStocks(table(1,index),1);
	end
end

