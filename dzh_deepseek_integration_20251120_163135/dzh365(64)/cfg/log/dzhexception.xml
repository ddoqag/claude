<?xml version="1.0" encoding="GB2312"?>
<DzhLog>
<!--默认加载的category的name是default-->
<Load>default</Load>
<category name="dzhexception">
<Appender>dzhexception</Appender>
</category>
<!--name是category的Appender，类型是File，路径是log\dzh_formula\dzh_formula.txt， 大小是4M-->
<appender name="dzhexception" type="file" minlevel="warning" path="dzhexception\dzhexception.txt" size="5"/>
</DzhLog>
