# 智谱AI编码端点环境变量配置模板
# 复制此文件为 .env 并填写实际值

# 环境标识 (development, testing, staging, production)
ENVIRONMENT=development

# 智谱AI API配置
ZHIPU_AI_API_KEY=your_api_key_here
ZHIPU_AI_API_KEY_TEST=your_test_api_key_here
ZHIPU_AI_API_KEY_PROD=your_production_api_key_here

# 组织和项目ID
ZHIPU_ORG_ID=your_org_id_here
ZHIPU_PROJECT_ID=your_project_id_here

# 加密密钥（使用 Fernet 生成）
ENCRYPTION_KEY=your_encryption_key_here
ENCRYPTION_KEY_TEST=your_test_encryption_key_here
ENCRYPTION_KEY_PROD=your_production_encryption_key_here

# JWT密钥
JWT_SECRET=your_jwt_secret_here
JWT_SECRET_TEST=your_test_jwt_secret_here
JWT_SECRET_PROD=your_production_jwt_secret_here

# 数据库配置
DB_PASSWORD=your_db_password_here
TEST_DB_HOST=localhost
TEST_DB_PASSWORD=your_test_db_password_here
PROD_DB_HOST=your_prod_db_host_here
PROD_DB_PASSWORD=your_prod_db_password_here

# 缓存配置
TEST_CACHE_HOST=localhost
TEST_CACHE_PASSWORD=your_test_cache_password_here
PROD_CACHE_HOST=your_prod_cache_host_here
PROD_CACHE_PASSWORD=your_prod_cache_password_here

# 应用配置
APP_NAME=ZhipuAI编码端点
APP_VERSION=1.0.0
APP_DEBUG=true
APP_PORT=8080

# 监控和追踪
SENTRY_DSN=your_sentry_dsn_here
PROMETHEUS_PORT=9090

# 外部服务
REDIS_URL=redis://localhost:6379/0
WEBHOOK_URL=your_webhook_url_here
EMAIL_SERVICE_API_KEY=your_email_api_key_here